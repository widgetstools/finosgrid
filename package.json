{
  "name": "finosgrid",
  "private": true,
  "version": "0.1.0",
  "description": "AG Grid–like Perspective datagrid (FINOS compute engine + chrome UI)",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build -w @widgetstools/finosgrid",
    "test": "npm run test -w @widgetstools/finosgrid",
    "demo": "npm run start -w ag-chrome-demo",
    "demo:ag": "npm run start -w ag-grid-reference",
    "demo:shell": "npm run start -w shell-spike",
    "start": "npm run demo"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/widgetstools/finosgrid.git"
  },
  "license": "Apache-2.0"
}
